RULE {
  ?X a :A2 .
}
WHERE {
  ?X a :N1000 .
}

RULE {
  :arc :check1 "C1 OK - the starting classification N0 is present." .
}
WHERE {
  :ind a :N0 .
}

RULE {
  :arc :check2 "C2 OK - the first expansion produced N1 together with side labels I1 and J1." .
}
WHERE {
  :ind a :N1 .
  :ind a :I1 .
  :ind a :J1 .
}

RULE {
  :arc :check3 "C3 OK - the chain reaches the midpoint N500 and still carries both side-label branches." .
}
WHERE {
  :ind a :N500 .
  :ind a :I500 .
  :ind a :J500 .
}

RULE {
  :arc :check4 "C4 OK - the final taxonomy step from N999 to N1000 was completed." .
}
WHERE {
  :ind a :N999 .
  :ind a :N1000 .
}

RULE {
  :arc :check5 "C5 OK - once N1000 is reached, the terminal class A2 is derived." .
}
WHERE {
  :ind a :N1000 .
  :ind a :A2 .
}

RULE {
  :arc :check6 "C6 OK - the success flag is raised only after the terminal class A2 is present." .
}
WHERE {
  :ind a :A2 .
  :test :is true .
}

RULE {
  :report log:outputString "Deep Taxonomy - deep classification benchmark\n\nAnswer\nThe test succeeds: starting from one individual classified as N0, the rules eventually classify it as N1000 and then as A2.\n\nReason Why\nEach rule moves the same individual one level deeper in the taxonomy and also adds two side labels. Because that chain continues all the way from N0 to N1000, the final rule deriving A2 fires, and that in turn makes the test true.\n\nCheck\nC1 OK - the starting classification N0 is present.\nC2 OK - the first expansion produced N1 together with side labels I1 and J1.\nC3 OK - the chain reaches the midpoint N500 and still carries both side-label branches.\nC4 OK - the final taxonomy step from N999 to N1000 was completed.\nC5 OK - once N1000 is reached, the terminal class A2 is derived.\nC6 OK - the success flag is raised only after the terminal class A2 is present." .
}
WHERE {
  :test :is true .
  :arc :check1 ?C1 .
  :arc :check2 ?C2 .
  :arc :check3 ?C3 .
  :arc :check4 ?C4 .
  :arc :check5 ?C5 .
  :arc :check6 ?C6 .
}

